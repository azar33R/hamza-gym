# Supabase — copy this file to .env.local and fill in real values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push (VAPID) — OPTIONAL. Required for real OS-level push notifications.
# Generate keys with:  npx web-push generate-vapid-keys
# If left blank, notifications are still stored in the DB but not delivered
# to devices.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT_EMAIL=mailto:you@example.com
