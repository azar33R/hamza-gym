# Supabase — copy this file to .env.local and fill in real values
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push (VAPID) — OPTIONAL. Required for real OS-level push notifications.
# Generate keys with:  npx web-push generate-vapid-keys
# If left blank, notifications are still stored in the DB but not delivered
# to devices.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT_EMAIL=mailto:you@example.com

# Google Gemini — Food Scanner vision API (gemini-3.1-flash-lite by default)
# Provide up to two keys; the analyzer falls back to the second on quota errors.
GEMINI_API_KEY=your-gemini-key
GEMINI_API_KEY_2=
# Optional: override the model, e.g. gemini-3.1-flash-lite
GEMINI_MODEL=
